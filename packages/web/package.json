{
  "name": "@agentops/web",
  "version": "0.1.0",
  "description": "Web dashboard for AgentOps — the control plane for autonomous AI agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentops-ai/agentops",
    "directory": "packages/web"
  },
  "files": [".next/standalone", ".next/static", "public", "README.md", "LICENSE"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "mkdir -p .next/standalone/packages/web/.next && cp -r .next/static .next/standalone/packages/web/.next/static && (cp -r public .next/standalone/packages/web/public 2>/dev/null || true)",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@agentops/core": "*",
    "@agentops/db": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
