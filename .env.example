# Copy to .env and fill in the values you want.
#
# Variables here are read by docker-compose.yml. Variables consumed by the CLI
# on a developer machine live in ~/.agentops/credentials.json (managed by
# `agentops login`) — they do NOT belong in a shared .env.

# ─── Dashboard ────────────────────────────────────────────────────────────────

# Optional. If set, the Usage page proxies to the Anthropic Admin API and
# surfaces org-level cost/usage. Get a key from console.anthropic.com.
# ANTHROPIC_ADMIN_API_KEY=

# ─── Backup (Litestream → S3) ────────────────────────────────────────────────
# Only read when you start the backup sidecar:
#   docker compose --profile backup up -d
# Without these, the litestream service won't start; dashboard runs normally.

# Required when the backup profile is enabled.
# AGENTOPS_S3_BUCKET=my-agentops-backups

# Optional. Defaults if unset:
#   AGENTOPS_S3_PREFIX = agentops
#   AWS_REGION         = us-east-1
# AGENTOPS_S3_PREFIX=agentops
# AWS_REGION=us-east-1

# Required for AWS S3. Or use IAM instance roles if running on EC2 / ECS.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: override endpoint for S3-compatible stores (MinIO, R2, Wasabi).
# Example for Cloudflare R2:
#   AGENTOPS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# AGENTOPS_S3_ENDPOINT=
